# =============================================================================
# CICI Configuration
# =============================================================================
# Copy this file to .env and customize values for your environment.
# All services read from this single configuration file.

# -----------------------------------------------------------------------------
# Service Endpoints
# -----------------------------------------------------------------------------
# Hosts and ports for each microservice. For local development, use localhost.
# For Docker deployment, use service names (mind, ears, mouth, face).

MIND_HOST=localhost
MIND_PORT=8765

EARS_HOST=localhost
EARS_PORT=8766

MOUTH_HOST=localhost
MOUTH_PORT=8001

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Ollama LLM inference server
OLLAMA_HOST=http://192.168.50.2:31435
OLLAMA_MODEL=phi3

# Claude model for API calls
CLAUDE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Audio Settings
# -----------------------------------------------------------------------------
# Sample rate for audio processing (Hz) - must match across EARS and FACE
SAMPLE_RATE=16000

# Silence duration (ms) to trigger transcription after speech ends
EARS_SILENCE_DURATION_MS=1000

# Enable EARS debug mode (returns per-chunk audio analysis)
EARS_DEBUG=true

# -----------------------------------------------------------------------------
# Piper TTS Model
# -----------------------------------------------------------------------------
# Voice model name from https://huggingface.co/rhasspy/piper-voices
# Format: {lang}_{region}-{speaker}-{quality} (e.g., en_GB-jenny_dioco-medium)
PIPER_VOICE=en_GB-jenny_dioco-medium

# Output sample rate (Hz) - determined by model, typically 22050
PIPER_SAMPLE_RATE=22050

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Default working directory for Claude Code mode
DEFAULT_CWD=/infra/experiments/cici

# -----------------------------------------------------------------------------
# Browser-Accessible URLs (for non-localhost deployments)
# -----------------------------------------------------------------------------
# These override the constructed URLs when deploying to remote hosts.
# Uncomment and set for production deployments.
# CICI_EARS_WS_URL=ws://your-host:8766
# CICI_MOUTH_URL=http://your-host:8001
