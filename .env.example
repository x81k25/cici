# CICI Docker Compose Configuration

# Anthropic API key for Claude integration (optional)
ANTHROPIC_API_KEY=

# Ollama server URL (optional, defaults to local network)
OLLAMA_HOST=http://192.168.50.2:31435

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# EARS configuration
EARS_SILENCE_DURATION_MS=1000

# Browser-accessible URLs (for non-localhost deployments)
# These are used by the browser to connect to EARS/MOUTH
# CICI_EARS_WS_URL=ws://your-host:8766/?debug=true
# CICI_MOUTH_URL=http://your-host:8001
