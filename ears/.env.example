# EARS Configuration

# Silence duration (ms) to trigger transcription after speech
# Lower = faster response, but may cut off mid-thought
# Higher = waits longer for pauses
EARS_SILENCE_DURATION_MS=1000

# MIND service URL for forwarding transcriptions
EARS_MIND_URL=http://localhost:8765

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
